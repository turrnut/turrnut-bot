import socket
import threading

HEADER = 64
PORT = 6787
SERVER = socket.gethostbyname(socket.gethostname())
FORMAT = 'utf-8'
ADDR = (SERVER, PORT)
DISCONN = "?DISCONN"

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.bind(ADDR)

def receive_msg(connection, addr):
    print(f"{addr[0]}:{addr[1]} connected to {SERVER}:{PORT} ")

    while True:
        msg_len = connection.recv(HEADER).decode(FORMAT)
        if not msg_len: break
        msg_len = int(msg_len)
        msg = connection.recv(msg_len).decode(FORMAT)
        if msg == DISCONN:
            print(f"{addr[0]}:{addr[1]} DISCONNECTED")
            return
        print(f"{addr[0]}:{addr[1]} -> {msg}")
    connection.close()
def start():
    print(f"SERVER STARTED {SERVER}:{PORT}")
    server.listen()
    while True:
        print(f"Active Connections: {threading.active_count() - 1}")
        connection, addr = server.accept()
        thread = threading.Thread(target=receive_msg, args=(connection,addr))
        thread.start()
        print(f"Active Connections: {threading.active_count() - 1}")
start()

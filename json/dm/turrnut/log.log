import socket
import sys
import threading
HEADER = 64
PORT = 6787
FORMAT = 'utf-8'
DISCONN = '?DISCONN'
SERVER = "10.0.0.75"

ADDR = (SERVER, PORT)

MYSERVER = socket.gethostbyname(socket.gethostname())
MYADDR = (MYSERVER, PORT)

server = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
server.bind(MYADDR)

def receive_msg(connection, addr):
    print(f"{addr[0]}:{addr[1]} connected to {MYSERVER}:{PORT} ")

    while True:
        msg_len = connection.recv(HEADER).decode(FORMAT)
        if not msg_len: break
        msg_len = int(msg_len)
        msg = connection.recv(msg_len).decode(FORMAT)
        if msg == DISCONN:
            print(f"{addr[0]}:{addr[1]} DISCONNECTED")
            return
        print(f"{addr[0]}:{addr[1]} -> {msg}")
    connection.close()
def start():
    print(f"MYSERVER STARTED {MYSERVER}:{PORT}")
    server.listen()
    while True:
        print(f"Active Connections: {threading.active_count() - 1}")
        connection, addr = server.accept()

        client.connect((ip,port))
        while True:
            msg = input("MSG: ")
            start()
            if msg == DISCONN:
                send(DISCONN)
                break
            send(msg)
except EOFError:    
    send(DISCONN)
except KeyboardInterrupt:
    send(DISCONN)
except Error as e:
    print(e)
    sys.exit(1)
    
    

